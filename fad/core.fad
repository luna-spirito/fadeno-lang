Key = List Int8+
EventId = List Int32+

// TODO: Enforce event-generator ownership somehow?
Event =
  {( .tag = Tag | .Ty = SuperType )}
  \archetype/ {( .sender = Key | .val = archetype.Ty })

//Gear = \Cfg Out. Record (meta : { Cache : Type+ u } \/ { initial : meta.Cache | step : Cfg -> meta.Cache -> Out })

Gear = \Cfg Out.

events =
  [ .from_rufoundation => {( .file = Blob )}
  | .update_article => {( .prev = Opt EventIdv | .title = Text | .body = Text )}
  ]
