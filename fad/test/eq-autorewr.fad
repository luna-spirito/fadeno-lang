// Tests for automatic inference of parameters for rewrites.
// We construct parametric rewrite `myeq` and verify that parameters `{x}`, `{y}` get inferred
// automatically.

unpack fadeno. Eq Any

/: Any
opaque boink = SORRY
/: Any
opaque gloink = SORRY
/: Any
opaque doing = SORRY

/: doing (boink gloink)
myval = SORRY

// Parametric rewrite with implicit arguments `{x}` and `{y}`
/: Fun {x} {y} -> Eq (doing (x y)) (x y)
myeq = SORRY

in
  // Begin scoped rewrite without providing explicit `{x}` and `{y}
  rewrite myeq in
    myval

// Expected result: rewrite `myeq` is provided to the type of `myval` after `{x}` and `{y}` are automatically inferred.
// Final type: `boink glonk` (/test/golden/eq-autorewr.golden)
