// Regression test for inference of polymorphic functions

unpack fadeno. Type^ Int

/: Fun {T} (T) -> T
id = \x. x

/: @|T : Type^ 0| T
useful = @|Int| 4

in
  { .idid = id id
  // ^ Expected `: Fun {A} (A) -> A`
  | .iduseful = id @(@|T : Type^ 0| T) useful
  // ^ Expected `: Fun @|T : fadeno.Type^ 0|
  }
