Type+ = fadeno.Type+
Kind = Type+ 1

/: Kind
Type = Type+ 0

/: Type
U32 = fadeno.U32
/: Type
Tag = fadeno.Tag

// TODO: Type
Row = fadeno.Row

// TODO: Type
Record = fadeno.Record

/: forall (u : U32) (a : Type+ u). a -> a
id = \x. x

// Union = Record (meta : { .tag = Tag } /\ { .val = U32 })
Union = \cases. Record (meta : { .tag = Tag } /\ fadeno.record-get meta.tag cases)

in fadeno.record-get
