unpack fadeno. Type+ UInt SInt Tag List Bool Eq refl Row Record list-length list-indexl if _<_ _+_ _*_ W wrap unwrap nat~fold Never

Kind = Type+ 1
/: Kind
Type = Type+ 0

/: u : UInt -@> A : Type+ u -@> A -> A
id = \x. x

/: u : UInt -@> K : Type+ u -@> V : Type+ u -@> K -> V -> Record { .k = K | .v = V }
_=>_ = \k v. { .k = k | .v = v }

/: Type
Unit = Record {}
/: Unit
unit = {}

/: u : UInt -@> Type+ u -> Type+ u
Not = \a. a -> Never

/: Bool -> Type
Where = \x. Eq x true

/: u : UInt -@> Acc : Type+ u -@> Acc -> (UInt -> Acc -> Acc) -> UInt -> Acc
nat-fold = \@u @Acc. nat~fold @u @(\_. Acc)

